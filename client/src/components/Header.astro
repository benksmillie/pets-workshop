---
// Import any necessary dependencies
---

<header class="bg-white dark:bg-[#24292f] disco:bg-gradient-to-r disco:from-pink-500 disco:to-yellow-500 border-b border-gray-300 dark:border-gray-800 disco:border-pink-400 transition-colors">
  <div class="container mx-auto flex justify-between items-center px-4 py-3 max-w-7xl">
    <div class="flex items-center gap-6">
      <h1 class="text-xl font-semibold text-gray-900 dark:text-white disco:text-white">
        <a href="/" class="hover:text-gray-600 dark:hover:text-gray-300 disco:hover:text-yellow-300 transition-colors flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 disco:animate-pulse" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
          </svg>
          <span>Tailspin Shelter</span>
        </a>
      </h1>
      <nav class="hidden md:flex gap-4">
        <a href="/" class="text-gray-700 dark:text-white disco:text-white hover:text-gray-900 dark:hover:text-gray-300 disco:hover:text-yellow-300 font-medium transition-colors px-2 py-1">Home</a>
        <a href="/about" class="text-gray-700 dark:text-white disco:text-white hover:text-gray-900 dark:hover:text-gray-300 disco:hover:text-yellow-300 font-medium transition-colors px-2 py-1">About</a>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <button id="theme-toggle" class="text-gray-700 dark:text-white disco:text-white hover:bg-gray-100 dark:hover:bg-[#30363d] disco:hover:bg-pink-600 p-2 rounded-md transition-colors" aria-label="Toggle theme">
        <svg id="theme-icon-light" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
        </svg>
        <svg id="theme-icon-dark" class="h-5 w-5 hidden" fill="currentColor" viewBox="0 0 20 20">
          <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
        </svg>
        <svg id="theme-icon-disco" class="h-5 w-5 hidden disco:animate-pulse" fill="currentColor" viewBox="0 0 20 20">
          <path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zM8 16v-1h4v1a2 2 0 11-4 0zM12 14c.015-.34.208-.646.477-.859a4 4 0 10-4.954 0c.27.213.462.519.476.859h4.002z" />
        </svg>
      </button>
      <button id="menu-toggle" class="md:hidden text-gray-700 dark:text-white disco:text-white focus:outline-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  <nav id="mobile-menu" class="hidden md:hidden bg-gray-50 dark:bg-[#1c2128] disco:bg-purple-700 border-t border-gray-300 dark:border-gray-800 disco:border-yellow-400 transition-colors">
    <ul class="py-2">
      <li><a href="/" class="block px-4 py-3 hover:bg-gray-100 dark:hover:bg-[#2d333b] disco:hover:bg-pink-600 text-gray-700 dark:text-white disco:text-white transition-colors">Home</a></li>
      <li><a href="/about" class="block px-4 py-3 hover:bg-gray-100 dark:hover:bg-[#2d333b] disco:hover:bg-pink-600 text-gray-700 dark:text-white disco:text-white transition-colors">About</a></li>
    </ul>
  </nav>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }

  // Theme toggle with 3 states: light -> dark -> disco
  const themeToggle = document.getElementById('theme-toggle');
  const themeIconLight = document.getElementById('theme-icon-light');
  const themeIconDark = document.getElementById('theme-icon-dark');
  const themeIconDisco = document.getElementById('theme-icon-disco');
  const html = document.documentElement;

  // Check for saved theme preference or default to light mode
  const currentTheme = localStorage.getItem('theme') || 'light';
  
  function updateThemeIcon(theme) {
    themeIconLight?.classList.add('hidden');
    themeIconDark?.classList.add('hidden');
    themeIconDisco?.classList.add('hidden');
    
    if (theme === 'light') {
      themeIconLight?.classList.remove('hidden');
    } else if (theme === 'dark') {
      themeIconDark?.classList.remove('hidden');
    } else if (theme === 'disco') {
      themeIconDisco?.classList.remove('hidden');
    }
  }
  
  function applyTheme(theme) {
    html.classList.remove('dark', 'disco');
    
    if (theme === 'dark') {
      html.classList.add('dark');
    } else if (theme === 'disco') {
      html.classList.add('disco');
    }
    
    updateThemeIcon(theme);
    localStorage.setItem('theme', theme);
  }
  
  applyTheme(currentTheme);

  themeToggle?.addEventListener('click', () => {
    const current = localStorage.getItem('theme') || 'light';
    let next;
    
    if (current === 'light') {
      next = 'dark';
    } else if (current === 'dark') {
      next = 'disco';
    } else {
      next = 'light';
    }
    
    applyTheme(next);
  });
</script>